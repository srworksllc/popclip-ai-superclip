{
  "name": "AI SuperClip",
  "version": "1.2.0",
  "icon": "symbol:brain",
  "identifier": "com.srworks.popclip.extension.ai-superclip",
  "description": "Send the selected text to your preferred LLM and pastes the response. Hold Shift (\u21e7) to copy the response to the clipboard.",
  "author": "Steve Reinhardt",
  "authorURL": "https://srworks.co",
  "popclipVersion": 4069,
  "module": "settings.js",
  "entitlements": [
    "network"
  ],
  "options": [
    {
      "identifier": "apikeys-heading",
      "type": "heading",
      "label": "API Keys"
    },
    {
      "identifier": "groqapikey",
      "label": "Groq",
      "type": "string",
      "description": "console.groq.com/keys"
    },
    {
      "identifier": "apikey",
      "label": "OpenAI",
      "type": "string",
      "description": "platform.openai.com/api-keys"
    },
    {
      "identifier": "claudeapikey",
      "label": "Anthropic Claude",
      "type": "string",
      "description": "console.anthropic.com/settings/keys"
    },
    {
      "identifier": "mistralapikey",
      "label": "Mistral",
      "type": "string",
      "description": "console.mistral.ai/api-keys"
    },
    {
      "identifier": "model",
      "label": "Provider",
      "type": "multiple",
      "defaultValue": "groq",
      "values": [
        "groq",
        "openai",
        "claude",
        "mistral"
      ],
      "valueLabels": [
        "Groq (Free, Fast)",
        "OpenAI",
        "Anthropic Claude",
        "Mistral"
      ]
    },
    {
      "identifier": "tone",
      "label": "Tone",
      "type": "multiple",
      "defaultValue": "default",
      "values": [
        "default",
        "professional",
        "casual",
        "friendly",
        "direct"
      ],
      "valueLabels": [
        "Default",
        "Professional",
        "Casual",
        "Friendly",
        "Direct"
      ]
    },
    {
      "identifier": "actions-heading",
      "type": "heading",
      "label": "Actions"
    },
    {
      "identifier": "enable-improve-writing",
      "label": "Improve Writing",
      "type": "boolean",
      "defaultValue": true,
      "inset": true
    },
    {
      "identifier": "enable-spelling-grammar",
      "label": "Spelling & Grammar",
      "type": "boolean",
      "defaultValue": true,
      "inset": true
    },
    {
      "identifier": "enable-make-longer",
      "label": "Make Longer",
      "type": "boolean",
      "defaultValue": true,
      "inset": true
    },
    {
      "identifier": "enable-make-shorter",
      "label": "Make Shorter",
      "type": "boolean",
      "defaultValue": true,
      "inset": true
    },
    {
      "identifier": "enable-summarize",
      "label": "Summarize",
      "type": "boolean",
      "defaultValue": true,
      "inset": true
    },
    {
      "identifier": "version-heading",
      "type": "heading",
      "label": "Version 1.2.0 \u00b7 srworks.co"
    }
  ]
}
