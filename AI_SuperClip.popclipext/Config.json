{
  "name": "AI SuperClip",
  "version": "1.1.7",
  "icon": "symbol:brain",
  "identifier": "com.srworks.popclip.extension.ai-superclip",
  "description": "Send the selected text to your preferred LLM and pastes the response. Hold Shift (\u21e7) to copy the response to the clipboard.",
  "author": "Steve Reinhardt",
  "authorURL": "https://srworks.co",
  "popclipVersion": 4069,
  "module": "settings.js",
  "entitlements": [
    "network"
  ],
  "options": [
    {
      "identifier": "apikeys-heading",
      "type": "heading",
      "label": "API Keys"
    },
    {
      "identifier": "groqapikey",
      "label": "Groq",
      "type": "string",
      "description": "console.groq.com/keys"
    },
    {
      "identifier": "apikey",
      "label": "OpenAI",
      "type": "string",
      "description": "platform.openai.com/api-keys"
    },
    {
      "identifier": "claudeapikey",
      "label": "Anthropic Claude",
      "type": "string",
      "description": "console.anthropic.com/settings/keys"
    },
    {
      "identifier": "mistralapikey",
      "label": "Mistral",
      "type": "string",
      "description": "console.mistral.ai/api-keys"
    },
    {
      "identifier": "geminiapikey",
      "label": "Google Gemini",
      "type": "string",
      "description": "ai.google.dev"
    },
    {
      "identifier": "model",
      "label": "Model",
      "type": "multiple",
      "defaultValue": "llama-3.3-70b-versatile",
      "values": [
        "llama-3.3-70b-versatile",
        "meta-llama/llama-4-scout-17b-16e-instruct",
        "gpt-4.1",
        "gpt-4.1-mini",
        "claude-sonnet-4-6",
        "claude-haiku-4-5-20251001",
        "mistral-medium-latest",
        "mistral-small-latest",
        "gemini-2.5-pro",
        "gemini-2.5-flash"
      ],
      "valueLabels": [
        "Groq: Llama 3.3 70B",
        "Groq: Llama 4 Scout",
        "OpenAI: GPT-4.1",
        "OpenAI: GPT-4.1 Mini",
        "Claude: Sonnet 4.6",
        "Claude: Haiku 4.5 (Fast)",
        "Mistral: Medium",
        "Mistral: Small (Fast)",
        "Gemini: 2.5 Pro",
        "Gemini: 2.5 Flash"
      ]
    },
    {
      "identifier": "tone",
      "label": "Tone",
      "type": "multiple",
      "defaultValue": "default",
      "values": [
        "default",
        "professional",
        "casual",
        "friendly",
        "direct"
      ],
      "valueLabels": [
        "Default",
        "Professional",
        "Casual",
        "Friendly",
        "Direct"
      ]
    },
    {
      "identifier": "actions-heading",
      "type": "heading",
      "label": "Actions"
    },
    {
      "identifier": "enable-improve-writing",
      "label": "Improve Writing",
      "type": "boolean",
      "defaultValue": true,
      "inset": true
    },
    {
      "identifier": "enable-spelling-grammar",
      "label": "Spelling & Grammar",
      "type": "boolean",
      "defaultValue": true,
      "inset": true
    },
    {
      "identifier": "enable-make-longer",
      "label": "Make Longer",
      "type": "boolean",
      "defaultValue": true,
      "inset": true
    },
    {
      "identifier": "enable-make-shorter",
      "label": "Make Shorter",
      "type": "boolean",
      "defaultValue": true,
      "inset": true
    },
    {
      "identifier": "enable-summarize",
      "label": "Summarize",
      "type": "boolean",
      "defaultValue": true,
      "inset": true
    },
    {
      "identifier": "version-heading",
      "type": "heading",
      "label": "Version 1.1.7 \u00b7 srworks.co"
    }
  ]
}
